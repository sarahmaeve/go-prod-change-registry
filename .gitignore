# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

bin/

# Stray binaries from `go build ./cmd/<name>` without -o (named after the package dir).
/smoke

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# SQLite database files
*.db
*.db-wal
*.db-shm

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Local Claude Code project config (instructions, agents, settings).
# Keep these out of source control so each contributor can have their own.
CLAUDE.md
.claude/
